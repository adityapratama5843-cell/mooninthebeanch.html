     </div>
    </section><!-- Footer -->
    <section class="px-4 py-16 text-center section-fade">
     <p class="text-cyan-300/40 text-sm">✦ Moonlit Shore ✦ Where the ocean meets the stars ✦</p>
    </section>
   </div><!-- Audio control --> <button id="audio-btn" class="fixed bottom-6 right-6 z-50 w-12 h-12 rounded-full glass-card flex items-center justify-center text-cyan-300 hover:text-white transition-colors" aria-label="Toggle sound"> <i data-lucide="volume-2" id="audio-icon-on" style="width:20px;height:20px;"></i> <i data-lucide="volume-x" id="audio-icon-off" style="width:20px;height:20px;display:none;"></i> </button>
