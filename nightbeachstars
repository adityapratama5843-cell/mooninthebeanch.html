<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Moonlit Shore</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&amp;family=Quicksand:wght@300;400;500&amp;display=swap" rel="stylesheet">
  <style>
    html, body { height: 100%; margin: 0; overflow-x: hidden; }
    body { font-family: 'Quicksand', sans-serif; background: #0a0e1a; }
    .font-heading { font-family: 'Cormorant Garamond', serif; }

    /* Stars */
    .star {
      position: absolute;
      width: 2px; height: 2px;
      background: white;
      border-radius: 50%;
      animation: twinkle var(--dur) ease-in-out infinite;
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.5); }
    }

    /* Shooting stars */
    .shooting-star {
      position: absolute;
      width: 120px; height: 2px;
      background: linear-gradient(to right, transparent, #4fc3f7, #00e5ff);
      border-radius: 2px;
      animation: shoot 3s linear infinite;
      opacity: 0;
      filter: drop-shadow(0 0 6px #00e5ff);
    }
    @keyframes shoot {
      0% { transform: translateX(0) translateY(0); opacity: 1; }
      100% { transform: translateX(-400px) translateY(300px); opacity: 0; }
    }

    /* Fireflies */
    .firefly {
      position: absolute;
      width: 6px; height: 6px;
      background: radial-gradient(circle, #80deea, transparent);
      border-radius: 50%;
      animation: float var(--dur) ease-in-out infinite;
      box-shadow: 0 0 8px #80deea, 0 0 16px #4dd0e1;
    }
    @keyframes float {
      0%, 100% { transform: translate(0, 0); }
      25% { transform: translate(var(--dx), var(--dy)); }
      50% { transform: translate(calc(var(--dx) * -0.5), calc(var(--dy) * 1.2)); }
      75% { transform: translate(calc(var(--dx) * 0.8), calc(var(--dy) * -0.6)); }
    }

    /* Glassmorphism card */
    .glass-card {
      background: rgba(10, 20, 40, 0.4);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(79, 195, 247, 0.2);
      box-shadow: 0 0 30px rgba(0, 229, 255, 0.1), inset 0 0 30px rgba(0, 229, 255, 0.05);
      animation: glow-border 4s ease-in-out infinite;
    }
    @keyframes glow-border {
      0%, 100% { border-color: rgba(79, 195, 247, 0.2); box-shadow: 0 0 30px rgba(0, 229, 255, 0.1); }
      50% { border-color: rgba(79, 195, 247, 0.5); box-shadow: 0 0 50px rgba(0, 229, 255, 0.25); }
    }

    /* Ocean waves */
    .wave {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 120px;
      background: linear-gradient(to top, rgba(10, 30, 60, 0.8), transparent);
      animation: wave-move 6s ease-in-out infinite;
    }
    .wave::before {
      content: '';
      position: absolute;
      bottom: 0; left: -10%; right: -10%;
      height: 60px;
      border-radius: 50% 50% 0 0;
      background: rgba(13, 71, 161, 0.3);
      animation: wave-shape 4s ease-in-out infinite;
    }
    @keyframes wave-move { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
    @keyframes wave-shape { 0%, 100% { transform: scaleX(1); } 50% { transform: scaleX(1.05); } }

    /* Gallery */
    .gallery-item {
      transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      border: 1px solid rgba(79, 195, 247, 0.15);
    }
    .gallery-item:hover {
      transform: scale(1.05) translateY(-8px);
      box-shadow: 0 20px 60px rgba(0, 229, 255, 0.3);
      border-color: rgba(79, 195, 247, 0.6);
    }

    /* Particles */
    .particle {
      position: absolute;
      width: 3px; height: 3px;
      background: rgba(128, 222, 234, 0.6);
      border-radius: 50%;
      animation: particle-float var(--dur) linear infinite;
      filter: blur(1px);
    }
    @keyframes particle-float {
      0% { transform: translateY(0) translateX(0); opacity: 0; }
      20% { opacity: 1; }
      80% { opacity: 1; }
      100% { transform: translateY(-200px) translateX(var(--dx)); opacity: 0; }
    }

    /* Smooth scroll */
    html { scroll-behavior: smooth; }

    .neon-text {
      text-shadow: 0 0 10px rgba(0, 229, 255, 0.5), 0 0 40px rgba(0, 229, 255, 0.2);
    }

    .section-fade {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .section-fade.visible { opacity: 1; transform: translateY(0); }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
