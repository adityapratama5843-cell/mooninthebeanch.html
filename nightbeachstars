 <body class="h-full overflow-auto">
  <div id="app" class="relative w-full" style="min-height: 100%;"><!-- Sky / Background -->
   <div class="fixed inset-0 bg-gradient-to-b from-[#040814] via-[#0a1628] to-[#0d2137]" id="sky"></div><!-- Stars container -->
   <div id="stars-container" class="fixed inset-0 pointer-events-none"></div><!-- Shooting stars -->
   <div id="shooting-stars" class="fixed inset-0 pointer-events-none"></div><!-- Particles -->
   <div id="particles" class="fixed inset-0 pointer-events-none"></div><!-- Fireflies -->
   <div id="fireflies" class="fixed inset-0 pointer-events-none"></div><!-- Ocean waves -->
   <div class="fixed bottom-0 left-0 right-0 pointer-events-none">
    <div class="wave"></div>
    <div class="wave" style="animation-delay: -2s; opacity: 0.5; height: 90px;"></div>
   </div><!-- Content -->
   <div class="relative z-10"><!-- Hero Section -->
    <section class="flex items-center justify-center px-4 py-16" style="min-height: 100%;">
